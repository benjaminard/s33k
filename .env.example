# s33k environment configuration (single-user, self-hosted).
#
# Copy this file to .env and fill it in: cp .env.example .env
# Every value below is a safe placeholder. Replace the ones marked REQUIRED
# before you run s33k, and never commit your real .env (it is gitignored).
#
# Two of these are secrets you MUST regenerate, not copy from anywhere:
#   SECRET  -> openssl rand -hex 34
#   APIKEY  -> openssl rand -hex 24

# === Secrets (REQUIRED, regenerate both) ====================================
# s33k is headless: there is no web login. The APIKEY below is the only
# credential, and first-run configuration happens on a one-time setup page
# whose token-gated URL is printed to the server log as a [SETUP] line on boot.
#
# SECRET encrypts stored credentials (in the database) and signs the one-time
# setup and key-drop tokens.
#   Generate with: openssl rand -hex 34
SECRET=replace-with-openssl-rand-hex-34
# APIKEY is the single Bearer token for the REST API and the MCP server. It is
# the only key s33k accepts, and the same value the MCP server reads.
#   Generate with: openssl rand -hex 24
APIKEY=replace-with-openssl-rand-hex-24

# === Database (Postgres in prod, SQLite locally) ============================
# DATABASE_URL is THE switch that selects the database. When set, s33k uses
# Postgres (recommended for a hosted deploy). When UNSET, s33k falls back to a
# local SQLite file, which is the simplest way to self-host on one machine.
# Note: SQLite on a mounted cloud volume is unreliable in the standalone runtime
# (see CLAUDE.md / DEPLOY.md); use Postgres when deploying to a platform.
#   Example: postgresql://user:password@host:5432/s33k
# DATABASE_URL=
# DATABASE_PATH: absolute path for the SQLite file (SQLite branch only, ignored
# under Postgres). Optional; defaults to ./data/database.sqlite.
# DATABASE_PATH=

# Public URL where this s33k instance is reached in a browser. Used to build the
# Google OAuth redirect URL below (and behind a reverse proxy). Optional for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PORT the s33k web server listens on. Optional, defaults to 3000.
# PORT=3000

# === SERP scraper (REQUIRED for live rankings) ==============================
# s33k scrapes live Google rankings. Serper is the day-one source: one key,
# results in about two minutes. Get a key at https://serper.dev.
# The key can also be pasted on the one-time setup page (stored encrypted in the
# database); these env values are the fallback used when the database has none.
SCRAPER_TYPE=serper
SERPER_API_KEY=your-serper-api-key
# SCAPING_API is the key used by scrapers other than Serper (for example
# scrapingrobot or scrapingant). Optional; only set it if SCRAPER_TYPE is one
# of those. The misspelling matches the upstream SerpBear variable name.
# SCAPING_API=
# SCREENSHOT_API is an optional key for a screenshot service. Optional.
# SCREENSHOT_API=

# === Onboarding keyword recommendation (optional) ===========================
# FIRECRAWL_API_KEY turns the onboarding "enter your domain" step into a single
# scrape that recommends the top ~50 keyword phrases to track, so you never type
# a keyword. When UNSET, onboarding falls back to a built-in heuristic crawler,
# so this is purely an upgrade. Get a key at https://firecrawl.dev.
# FIRECRAWL_API_KEY=

# === Scrape + rank-change email cadence (optional) ==========================
# SCRAPE_INTERVAL: how often the built-in cron re-checks Google rankings.
# Accepts "hourly", "daily", "weekly" (default), "monthly", or "never".
# SCRAPE_INTERVAL=weekly
# NOTIFICATION_INTERVAL: how often rank-change emails are sent. Accepts the same
# words plus "never" (the default = no emails). The SMTP server, the notification
# From/To addresses, and enabling email itself are stored encrypted in the
# database; write them with an authenticated call to /api/settings (a curl with
# your APIKEY Bearer header, see TROUBLESHOOTING.md), not via env vars.
# NOTIFICATION_INTERVAL=never

# === Google Search Console (optional) =======================================
# Connects GSC for the get_insight tool (top pages, keywords, countries, stats).
#
# Preferred: click-to-authorize OAuth. Create an OAuth 2.0 Web client in Google
# Cloud, add ${NEXT_PUBLIC_APP_URL}/api/searchconsole/callback as an authorized
# redirect URI, then set the two vars below. You connect with one click via the
# connect_search_console MCP tool, no JSON pasting. Both must be set together,
# or the connect endpoint reports "not configured".
# GSC_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# GSC_OAUTH_CLIENT_SECRET=your-oauth-client-secret
#
# Fallback: service-account credentials (still supported). Both must be set
# together, or leave both unset. Paste the private key as a single line with
# literal \n for newlines.
# SEARCH_CONSOLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# SEARCH_CONSOLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Analytics ingest rate limiting (optional) ==============================
# TRUSTED_PROXY_HOPS: how many trusted reverse proxies sit in front of s33k.
# It controls which X-Forwarded-For hop is trusted as the client IP for rate
# limiting; a wrong value lets clients spoof IPs. Default is 1 (one proxy).
# Cloudflare -> your host = 2.
# TRUSTED_PROXY_HOPS=1
# RATE_LIMIT_GLOBAL_MAX: hard ceiling on total requests per window across all
# keys (anti-flood backstop). Optional, defaults to 100000. Set 0 to disable.
# RATE_LIMIT_GLOBAL_MAX=100000
# COLLECT_RATE_LIMIT: max /api/collect analytics-ingest requests per IP per window.
# Optional, defaults to 600. COLLECT_RATE_WINDOW_MS defaults to 60000 (1 min).
# COLLECT_RATE_LIMIT=600
# COLLECT_RATE_WINDOW_MS=60000

# === AI-crawler ingest (optional, off by default) ===========================
# CRAWLER_INGEST_ENABLED gates the /api/crawler-hit ingest endpoint that records
# server-side AI-crawler hits (GPTBot, ClaudeBot, etc.). It is OFF unless set to
# the literal "true". Leave unset for the zero-config default (domain in, no feeder).
# CRAWLER_INGEST_ENABLED=false

# === Tracking beacon script URL (optional) ==================================
# The install snippet points at the s33k.js beacon. By default the snippet uses a
# relative "/s33k.js" path, since s33k serves the beacon from its own origin, so
# you normally do not set either of these. Override only if you serve the beacon
# from a different host than the app.
# S33K_SCRIPT_URL: full URL to s33k.js, used verbatim (highest precedence).
# S33K_SCRIPT_URL=
# S33K_BEACON_HOST: base URL that serves s33k.js; the snippet src becomes
# ${S33K_BEACON_HOST}/s33k.js when S33K_SCRIPT_URL is unset.
# S33K_BEACON_HOST=

# === Build note (optional) ==================================================
# The production build type-checks the bundled MCP tools, which needs more heap
# than Node's default. The build script already sets this; only override if your
# build runs out of memory on a smaller machine.
# NODE_OPTIONS=--max-old-space-size=8192
